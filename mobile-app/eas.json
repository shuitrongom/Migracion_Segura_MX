{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "cache": {
        "disabled": false
      }
    },
    "preview": {
      "distribution": "internal",
      "cache": {
        "disabled": false,
        "key": "preview-android-v1"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "production": {
      "cache": {
        "disabled": false,
        "key": "production-v1"
      },
      "android": {
        "buildType": "app-bundle",
        "enableProguardInReleaseBuilds": true,
        "includeSourceMaps": true
      },
      "ios": {
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production",
        "releaseStatus": "draft"
      },
      "ios": {
        "appleId": "sergio.huitron1702@gmail.com",
        "ascAppId": "6789283931",
        "appleTeamId": "GB9XT2L3V5"
      }
    }
  }
}
