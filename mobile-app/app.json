{
  "expo": {
    "name": "Migración Segura MX",
    "slug": "migracion-segura-mx",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "migracion-segura",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mx.migracion-segura.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para escanear documentos.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para subir documentos.",
        "NSFaceIDUsageDescription": "Usamos Face ID para proteger tu información migratoria."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "mx.migracion_segura.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.31322060365-46s1mlqv0mnfbiadu075m206quafsmna"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "429519f6-9f00-4a9a-84b3-67a1d30dbbe8"
      }
    }
  }
}
