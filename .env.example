# ============================================
# Migración Segura MX - Variables de Entorno
# ============================================
# Copiar este archivo como .env y completar los valores
#
# ESTRATEGIA DE COSTOS:
# - Año 1: Servicios gratuitos (Supabase, Vercel, Railway, Upstash, Resend, Firebase)
# - Año 2+: Migrar a AWS/GCP cuando el volumen lo justifique
#

# ---- Aplicación ----
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3001
MOBILE_DEEP_LINK_SCHEME=migracion-segura

# ---- Base de Datos (Supabase PostgreSQL - GRATIS hasta 500MB) ----
# Local: usa Docker PostgreSQL
# Producción: usa Supabase (https://supabase.com)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=migracion_segura
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
# Supabase connection string (producción):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ---- Redis (Upstash - GRATIS hasta 10K comandos/día) ----
# Local: usa Docker Redis
# Producción: usa Upstash (https://upstash.com)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Upstash (producción):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ---- JWT / Autenticación ----
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_REFRESH_EXPIRATION=7d

# ---- OAuth: Google ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ---- OAuth: Apple ----
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# ---- Email (Resend - GRATIS 3,000 emails/mes) ----
# https://resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@migracion-segura.mx
EMAIL_FROM_NAME=Migración Segura MX

# ---- SMS (Twilio - pago por uso, ~$0.05/SMS) ----
# Alternativa gratuita: usar solo email para verificación al inicio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---- WhatsApp ----
# Año 1: Enlace directo wa.me (gratis, sin API)
# Año 2+: Meta Business API cuando haya volumen
WHATSAPP_PHONE_NUMBER=+5215512345678
WHATSAPP_MODE=direct_link

# ---- Firebase (Push Notifications - GRATIS ilimitado) ----
# https://console.firebase.google.com
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ---- Almacenamiento de Documentos ----
# Opción 1 (Año 1): Supabase Storage (1GB gratis)
# Opción 2 (Año 1): Cloudflare R2 (10GB gratis, sin egress fees)
# Opción 3 (Año 2+): AWS S3 + CloudFront
STORAGE_PROVIDER=supabase
# Supabase Storage:
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=documentos
# Cloudflare R2 (alternativa):
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=migracion-segura-documents
R2_PUBLIC_URL=
# AWS S3 (futuro):
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=migracion-segura-documents

# ---- MinIO (Desarrollo Local - emula S3/R2) ----
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=migracion-segura-documents

# ---- Google Calendar (GRATIS) ----
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ---- Cifrado de Documentos ----
DOCUMENT_ENCRYPTION_KEY=your_aes_256_key_here_base64

# ---- Rate Limiting ----
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---- Logging ----
LOG_LEVEL=debug
LOG_FORMAT=json

# ---- Despliegue (Año 1 - Gratuito) ----
# Backend: Railway (https://railway.app) - 500 hrs/mes gratis
# Panel Admin: Vercel (https://vercel.com) - gratis
# Base de datos: Supabase - gratis
# Redis: Upstash - gratis
# Storage: Supabase Storage o Cloudflare R2 - gratis
